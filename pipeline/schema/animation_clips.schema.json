{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "anim_clips_v1",
  "description": "Compact per-bone keyframe animation. Channels target rig BONE NAMES, so one file animates every body skinned to the same rig profile. Angles in radians, translations in metres; root stays in place (no horizontal locomotion).",
  "type": "object",
  "required": ["anim_spec_version", "rig", "clips"],
  "additionalProperties": true,
  "$defs": {
    "keyframe": {
      "type": "array",
      "description": "[frame_number, [x, y, z]]",
      "items": [
        { "type": "number" },
        { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "channels": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rotation_euler": { "type": "array", "items": { "$ref": "#/$defs/keyframe" } },
        "location": { "type": "array", "items": { "$ref": "#/$defs/keyframe" } }
      }
    }
  },
  "properties": {
    "anim_spec_version": { "const": "anim_clips_v1" },
    "rig": { "type": "string", "description": "rig profile id whose bone names these channels target (e.g. bird_v1, biped_v1)" },
    "notes": { "type": "string" },
    "clips": {
      "type": "object",
      "description": "keyed by clip/state name (idle, walk, fly, attack, ...)",
      "additionalProperties": {
        "type": "object",
        "required": ["playback", "sample_frames", "fps"],
        "additionalProperties": true,
        "properties": {
          "playback": { "enum": ["loop", "once", "hold"] },
          "sample_frames": { "type": "integer", "minimum": 1, "description": "sprite frames sampled per direction" },
          "fps": { "type": "number", "exclusiveMinimum": 0 },
          "duration_frames": { "type": "integer", "minimum": 1, "description": "length of the authoring timeline the clip is sampled across" },
          "bones": {
            "type": "object",
            "description": "keyed by bone name; bones omitted stay at the bind pose",
            "additionalProperties": { "$ref": "#/$defs/channels" }
          }
        }
      }
    }
  }
}
