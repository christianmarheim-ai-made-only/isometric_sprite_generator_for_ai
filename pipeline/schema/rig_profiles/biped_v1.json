  "bind_pose_units": "metre, +Z up, +X forward; per-bone head/tail are world-space rest positions for a ~1.8 m figure",
  "bones": [
    { "name": "root",      "parent": null,    "head": [0.0, 0.0, 0.0],    "tail": [0.0, 0.0, 0.10] },
    { "name": "hips",      "parent": "root",  "head": [0.0, 0.0, 0.92],   "tail": [0.0, 0.0, 1.02] },
