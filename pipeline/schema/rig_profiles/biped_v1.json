    { "name": "foot.R",    "parent": "shin.R", "head": [0.0, -0.10, 0.08], "tail": [0.12, -0.10, 0.0] }
  ],
  "region_by_bone": {
    "head": "head",
    "spine": "torso", "chest": "torso", "hips": "torso",
    "arm.L": "arms", "forearm.L": "arms", "hand.L": "arms",
    "arm.R": "arms", "forearm.R": "arms", "hand.R": "arms",
    "thigh.L": "legs", "shin.L": "legs", "foot.L": "legs",
    "thigh.R": "legs", "shin.R": "legs", "foot.R": "legs"
  },
  "states": {
    "_note": "States a biped variant may deliver. A variant MUST deliver at least `idle`; others are optional. fps/playback/frames match pipeline/lockfiles/sprite_states.lock.json (the procedural biped library). Extra states beyond this list are allowed if the variant authors clips for them.",
    "idle":   { "required": true,  "frames": 1, "fps": 1,  "playback": "loop" },
    "walk":   { "required": false, "frames": 4, "fps": 8,  "playback": "loop" },
    "attack": { "required": false, "frames": 3, "fps": 12, "playback": "once" }
  }
