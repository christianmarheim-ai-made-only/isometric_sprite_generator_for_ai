{
  "asset_contract_version": "external_asset_v1",
  "variant_id": "grunt",
  "archetype": "biped",
  "files": { "mesh": "../test_meshes/grunt.glb", "animation_clips": "animation/combat_biped_anim.json" },
  "geometry": { "up": "y", "forward": "+x", "unit": "meter" },
  "rig": "biped_v1",
  "region_source": "material_name",
  "default_state": "idle",
  "animations": {
    "idle":        { "clip": "idle",        "frames": 1, "fps": 1,  "playback": "loop" },
    "walk":        { "clip": "walk",        "frames": 6, "fps": 10, "playback": "loop" },
    "crouch_idle": { "clip": "crouch_idle", "frames": 1, "fps": 1,  "playback": "loop" },
    "crouch_walk": { "clip": "crouch_walk", "frames": 4, "fps": 8,  "playback": "loop" },
    "jump":        { "clip": "jump",        "frames": 2, "fps": 6,  "playback": "loop" },
    "fall":        { "clip": "fall",        "frames": 2, "fps": 6,  "playback": "loop" },
    "hit":         { "clip": "hit",         "frames": 3, "fps": 14, "playback": "once" },
    "punch":       { "clip": "punch",       "frames": 4, "fps": 12, "playback": "once" },
    "death":       { "clip": "death",       "frames": 6, "fps": 10, "playback": "once" }
  },
  "notes": "CANONICAL rigged biped combat-unit template; clip names = engine ADR-044 vocabulary (walk plays now; punch/death play when the ADR-040/041 triggers land). Clone per unit: swap files.mesh for your biped (skinned to biped_v1, materials named head/torso/arms/legs) and keep animation_clips -- clips target bone NAMES so one combat_biped_anim.json drives every biped. death playback=once: the engine holds its final frame as the corpse. bake_asset.py embeds the clips and bakes in one command."
}
