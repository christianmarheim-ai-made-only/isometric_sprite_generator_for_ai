# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# OS
.DS_Store
Thumbs.db

# verify_set: keep the package (manifest + atlases + contact sheets + INDEX) but not the
# bulky per-frame renderer intermediates (regenerable via produce_verify_set.py)
pipeline/output/verify_set/*/color_*dir*.png
pipeline/output/verify_set/*/region_*dir*.png
pipeline/output/verify_set/*/_states.json
pipeline/output/verify_set/*/anim_meta.json
pipeline/output/verify_set/*/blender_meta.json

# packaging: ship the zip, not the regenerable staging tree (package_authoring_contract.py)
dist/model_authoring_contract_v1/
# spec-v2 bundle: commit the source tree, not the regenerable binary zip artifact
dist/*.zip

# production logs are per-run/volatile (timing + commit hash) -> regenerable, not committed
pipeline/output/verify_set/*/build_log.json
pipeline/output/verify_set/build_index.json

# arrow-pilot per-frame renderer intermediates (regenerable via generate_arrow_pilot.py)
pipeline/output/arrow_pilot/frames/

# batch bake output (regenerable via bake_batch.py)
pipeline/output/incoming_batch/
pipeline/output/new_creatures/
pipeline/output/warrior_calibration_1/

# calibration / skin-delta verification bakes (regenerable via bake_asset.py; not goldens yet)
pipeline/output/calibration_humanoid_v1/
pipeline/output/dragon_calibration_v3/
pipeline/output/dragon_green_skin_v3/

# delivered human reference art (NOT pipeline inputs -- the bake uses glb + materials + texture_atlas).
# Already-committed concept art (cow/ball) stays tracked; this keeps NEW deliveries' large refs out.
creative/incoming/*/concept_art/
creative/incoming/*/*_concept_art.png
